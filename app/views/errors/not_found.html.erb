<div class="error-page d-flex align-items-center">
  <div class="container py-5">
    <div class="error-page__body">
      <section class="error-card">
        <%= image_tag "Tofu Logo.png", alt: "Where's My Tofu", class: "error-logo" %>
        <div class="error-chip">404 error</div>
        <div class="error-code">404</div>
        <h1 class="error-title">The page you were looking for is not here.</h1>
        <p class="error-copy">The link may be outdated, the address may be mistyped, or the page may have moved.</p>

        <div class="error-actions">
          <%= link_to "Home", root_path, class: "btn error-btn-primary" %>
          <%= link_to "Login", new_user_session_path, class: "btn error-btn-secondary" %>
        </div>

        <p class="error-note">Everything you need at the store starts from the homepage.</p>
      </section>
    </div>
  </div>
</div>
