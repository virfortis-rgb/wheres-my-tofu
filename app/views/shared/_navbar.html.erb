<%# ── MOBILE BOTTOM TABS: nav links only, hidden on desktop ── %>
<nav class="bottom-tabs" aria-label="Mobile navigation">
  <%= link_to root_path,
      class: "bottom-tab #{'active' if current_page?(root_path)}" do %>
    <i class="fa-solid fa-house"></i>
    <span>Home</span>
  <% end %>
  <% if user_signed_in? %>
    <%= link_to lists_index_path,
        class: "bottom-tab #{'active' if current_page?(lists_index_path)}" do %>
      <i class="fa-solid fa-list"></i>
      <span>Lists</span>
    <% end %>
    <%= link_to new_scan_path,
        class: "bottom-tab #{'active' if current_page?(new_scan_path)}" do %>
      <i class="fa-solid fa-plus"></i>
      <span>Add a Flyer</span>
    <% end %>
  <% end %>

  <%# ──Profile ── %>
  <div class="user-menu bottom-user-menu" data-controller="dropdown">
    <button class="bottom-tab"
            data-action="click->dropdown#toggle"
            aria-label="Account menu"
            aria-haspopup="true">
      <%= image_tag 'me.png', class: "avatar" %>
      <span>Profile</span>
    </button>

    <div class="user-dropdown" data-dropdown-target="menu" role="menu">
      <% if user_signed_in? %>
        <%= link_to destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "dropdown-item",
          role: "menuitem" do %>
          <i class="fa-solid fa-right-from-bracket"></i>
          <span>Logout</span>
        <% end %>
      <% else %>
        <%= link_to new_user_session_path,
          class: "dropdown-item",
          role: "menuitem" do %>
          <i class="fa-solid fa-right-to-bracket"></i>
          <span>Login</span>
        <% end %>
      <% end %>
    </div>
  </div>
</nav>
